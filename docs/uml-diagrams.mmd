%% === State Diagram ===
stateDiagram-v2
    [*] --> Disconnected

    state Disconnected {
        [*] --> Idle
    }

    Disconnected --> Connecting : User clicks Connect

    state Connecting {
        [*] --> RequestingPort
        RequestingPort --> OpeningPort : Port selected
        OpeningPort --> Syncing : Port opened
        Syncing --> DetectingChip : Sync OK
        DetectingChip --> Connected : Chip detected
        RequestingPort --> Disconnected : User cancelled
        OpeningPort --> Disconnected : Open failed
        Syncing --> Disconnected : Sync timeout
    }

    state Connected {
        [*] --> FlashTab

        state FlashTab {
            [*] --> ReadyToFlash
            ReadyToFlash --> ConfiguringFiles : Add/remove file entries
            ConfiguringFiles --> ReadyToFlash : Files configured

            ReadyToFlash --> Flashing : Click Program
            state Flashing {
                [*] --> ChangingBaud
                ChangingBaud --> ErasingFlash : Baud set
                ErasingFlash --> WritingBlocks : Erased
                WritingBlocks --> VerifyingMD5 : All blocks written
                VerifyingMD5 --> WritingBlocks : Next file
                VerifyingMD5 --> FlashComplete : All files done
            }
            Flashing --> ReadyToFlash : Flash error
            FlashComplete --> ReadyToFlash : Reset
        }

        FlashTab --> MonitorTab : Switch tab

        state MonitorTab {
            [*] --> Monitoring
            Monitoring --> Monitoring : Read loop / send data
        }

        MonitorTab --> FlashTab : Switch tab
    }

    Connected --> Disconnecting : User clicks Disconnect
    Connected --> Disconnecting : Device unplugged
    Disconnecting --> Disconnected : Cleanup complete
